ACCOUNT_NAME=your_polymarket_username
POLY_PRIVATE_KEY=replace_with_private_key_no_0x_prefix
POLY_SIGNER_ADDRESS=0xYourSignerAddress

# Choose ONE signature type (from Polymarket docs):
# 0 = EOA (MetaMask standard wallet)
# 1 = POLY_PROXY (Magic Link users)
# 2 = GNOSIS_SAFE proxy wallet (most common for many users)
#
# Funder rules:
# - For signature type 1 or 2, set POLY_FUNDER_ADDRESS to the wallet shown on polymarket.com/settings.
# - For signature type 0, you can usually leave POLY_FUNDER_ADDRESS empty.
#
# Example for MetaMask EOA:
#   POLY_SIGNATURE_TYPE=0
#   POLY_FUNDER_ADDRESS=
#
# Example for proxy wallet:
#   POLY_SIGNATURE_TYPE=2
#   POLY_FUNDER_ADDRESS=0xYourProfileWalletOnPolymarket
POLY_FUNDER_ADDRESS=
POLY_SIGNATURE_TYPE=0

# Optional fallback CLOB API credentials
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# Safety default: keep dry-run enabled unless you intentionally go live
DRY_RUN=1

# Optional official weather + market context integrations
# NOAA / weather.gov is public and does not need a key.
# Weather Company powers the weather.com data products and does require a key.
# WeatherAPI.com via RapidAPI is a separate provider from weather.com.
WEATHERCOM_API_KEY=
WEATHERAPI_RAPIDAPI_KEY=
WEATHERAPI_RAPIDAPI_HOST=weatherapi-com.p.rapidapi.com

# Optional manager UI integrations
TRADINGVIEW_DEFAULT_SYMBOL=BINANCE:BTCUSDT
TRADINGVIEW_CHARTING_LIBRARY_ACCESS=0
TRADINGVIEW_LIBRARY_PATH=
CHATGPT_DEV_THREAD_URL=
