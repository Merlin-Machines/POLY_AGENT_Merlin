APP_NAME=polymarket_v2
APP_ENV=dev

# Safety defaults
DRY_RUN=1
EXECUTION_ENABLED=0
LIVE_TRADING_ENABLED=0

# Runtime tuning
POLL_INTERVAL_SECONDS=45
MAX_POSITIONS=10
MAX_TRADE_USD=4.0
EDGE_THRESHOLD=0.02
LOG_LEVEL=INFO

# Polymarket
POLYMARKET_HOST=https://clob.polymarket.com
POLY_PRIVATE_KEY=
POLY_FUNDER_ADDRESS=
POLY_SIGNATURE_TYPE=1

# Binance (optional for upcoming integration)
BINANCE_API_KEY=
BINANCE_API_SECRET=
